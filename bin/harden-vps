#!/usr/bin/env python3
from __future__ import annotations

import subprocess
import sys
from pathlib import Path


def main(argv: list[str] | None = None) -> int:
    args = argv if argv is not None else sys.argv[1:]
    repo_root = Path(__file__).resolve().parents[1]
    target = repo_root / "lib" / "bash" / "commands" / "harden_vps.sh"
    if not target.is_file():
        print(f"harden-vps wrapper error: script no encontrado: {target}", file=sys.stderr)
        return 2
    try:
        result = subprocess.run(["bash", str(target), *args], check=False)
    except FileNotFoundError:
        print("harden-vps wrapper error: bash no disponible en PATH", file=sys.stderr)
        return 2
    return int(result.returncode)


if __name__ == "__main__":
    raise SystemExit(main())
