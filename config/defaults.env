DEFAULT_USER="alex"
DEFAULT_HOME_BASE="/home"
DEFAULT_APPS_DIR="/home/alex/apps"
DEFAULT_REPOS_DIR="/home/alex/repos"
DEFAULT_BACKUPS_DIR="/home/alex/backups"
DEFAULT_SCRIPTS_DIR="/home/alex/scripts"

